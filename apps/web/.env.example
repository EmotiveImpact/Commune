VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_ENABLE_WEB_OBSERVABILITY=false
VITE_API_SLOW_MS=800
VITE_ROUTE_SLOW_MS=250
VITE_QUERY_SLOW_MS=600

# Web Push (VAPID) — public key is hardcoded in use-push-notifications.ts
# Private key is needed on the server (edge function) to send push notifications
# Generate new keys: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=your-vapid-private-key
